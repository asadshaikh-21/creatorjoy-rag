# =========================
# GEMINI
# =========================
GOOGLE_API_KEY=your_google_api_key_here

# Fast model for chat
GEMINI_MODEL_FAST=models/gemini-2.5-flash

# Optional higher quality model
GEMINI_MODEL_PRO=models/gemini-2.5-pro

# =========================
# VECTOR DATABASE
# =========================
CHROMA_PATH=./chromadb

# =========================
# APIFY
# =========================
APIFY_TOKEN=your_apify_token_here

# =========================
# WHISPER
# =========================
WHISPER_MODEL=base

# =========================
# SERVER
# =========================
HOST=0.0.0.0
PORT=5000

# =========================
# CORS
# =========================
FRONTEND_URL=http://localhost:5173

# =========================
# TEMP STORAGE
# =========================
TEMP_DIR=./temp

# =========================
# SESSION CONFIG
# =========================
SESSION_TTL_HOURS=24